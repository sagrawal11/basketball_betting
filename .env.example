# ─────────────────────────────────────────────────────────────────────────────
# Local development environment.   Copy to .env:   cp .env.example .env
#
# Placeholders ONLY — never commit real secrets. The live Upstash / R2 / Kaggle
# credentials currently sitting in connection.txt should be ROTATED; local dev
# uses the Docker Redis + MinIO below and needs no cloud credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Redis ──────────────────────────────────────────────────────────────────
# Local: the Docker service (hostname `redis` on the compose network).
# Prod/CI: set UPSTASH_REDIS_URL instead — app.py reads REDIS_URL or UPSTASH_REDIS_URL.
REDIS_URL=redis://redis:6379

# ── MinIO (local S3-compatible stand-in for Cloudflare R2) ───────────────────
# storage.py talks to R2_ENDPOINT_URL when set; leave it BLANK to use real R2.
R2_ENDPOINT_URL=http://minio:9000
R2_BUCKET_NAME=nba-data
# These are BOTH the S3 creds the backend uses AND the MinIO root creds — keep the
# pairs identical. MinIO requires user >= 3 chars and password >= 8 chars.
R2_ACCESS_KEY_ID=nba-local
R2_SECRET_ACCESS_KEY=change-me-locally
MINIO_ROOT_USER=nba-local
MINIO_ROOT_PASSWORD=change-me-locally
# Only needed for REAL Cloudflare R2 (leave blank when using MinIO):
R2_ACCOUNT_ID=

# ── Kaggle (nightly data pulls only; not needed to serve the API) ────────────
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_DEBUG=1

# ── Frontend ─────────────────────────────────────────────────────────────────
# Vite reads its env from lovable/ (not this file). It already defaults to
# http://localhost:5001/api; override only via lovable/.env (see lovable/.env.example).
